# ────────────────────────────────────────────────────────────────────
# Grace Advisory — environment variables
# Copy this file to .env.local for local dev. On Vercel, add these in
# Project Settings → Environment Variables.
# ────────────────────────────────────────────────────────────────────

# Mail FROM address shown in the inbox. Must be a verified sender on
# whichever provider you use below. Defaults to info@graceadvisory.com.au
# (a real, monitored mailbox). Switch to noreply@ if/when that's provisioned.
MAIL_FROM=info@graceadvisory.com.au

# ──── Path A — Resend (recommended) ─────────────────────────────────
# Sign up at https://resend.com, verify the graceadvisory.com.au domain,
# create an API key, paste it here.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ──── Path B — SMTP (fallback / use existing infrastructure) ────────
# Only set these if RESEND_API_KEY is NOT set.
# Microsoft 365 example:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@graceadvisory.com.au
# SMTP_PASS=your-mailbox-password-or-app-password
#
# Google Workspace example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@graceadvisory.com.au
# SMTP_PASS=your-16-char-app-password

# ──── Recipients ────────────────────────────────────────────────────
# Hard-coded in lib/seo.ts (Raj@ + Info@graceadvisory.com.au).
# Edit CONTACT_RECIPIENTS in lib/seo.ts to change.
